{
    "openapi": "3.0.0",
    "info": {
        "title": "TPDDSW API",
        "version": "1.0.0",
        "description": "API para gestión de usuarios, pedidos, productos y notificaciones."
    },
    "servers": [
        {
            "url": "http://localhost:3000"
        }
    ],
    "paths": {
        "/health-check": {
            "get": {
                "summary": "Verifica el estado del servidor",
                "responses": {
                    "200": {
                        "description": "Servidor funcionando"
                    }
                }
            }
        },
        "/usuario": {
            "post": {
                "summary": "Crear un usuario",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": { "$ref": "#/components/schemas/Usuario" }
                        }
                    }
                },
                "responses": {
                    "201": { "description": "Usuario creado" }
                }
            }
        },
        "/usuario/{usuarioId}": {
            "get": {
                "summary": "Obtener usuario por ID",
                "parameters": [
                    { "name": "usuarioId", "in": "path", "required": true, "schema": { "type": "string" } }
                ],
                "responses": {
                    "200": { "description": "Usuario encontrado" },
                    "404": { "description": "Usuario no encontrado" }
                }
            }
        },
        "/producto": {
            "post": {
                "summary": "Crear un producto",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": { "$ref": "#/components/schemas/Producto" }
                        }
                    }
                },
                "responses": {
                    "201": { "description": "Producto creado" }
                }
            }
        },
        "/producto/{productoId}": {
            "get": {
                "summary": "Obtener producto por ID",
                "parameters": [
                    { "name": "productoId", "in": "path", "required": true, "schema": { "type": "string" } }
                ],
                "responses": {
                    "200": { "description": "Producto encontrado" },
                    "404": { "description": "Producto no encontrado" }
                }
            }
        },
        "/pedido": {
            "post": {
                "summary": "Crear un pedido",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": { "$ref": "#/components/schemas/Pedido" }
                        }
                    }
                },
                "responses": {
                    "201": { "description": "Pedido creado" }
                }
            }
        },
        "/pedido/{pedidoId}": {
            "get": {
                "summary": "Obtener pedido por ID",
                "parameters": [
                    { "name": "pedidoId", "in": "path", "required": true, "schema": { "type": "string" } }
                ],
                "responses": {
                    "200": { "description": "Pedido encontrado" },
                    "404": { "description": "Pedido no encontrado" }
                }
            },
            "patch": {
                "summary": "Actualizar un pedido",
                "parameters": [
                    { "name": "pedidoId", "in": "path", "required": true, "schema": { "type": "string" } }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": { "$ref": "#/components/schemas/PedidoPatch" }
                        }
                    }
                },
                "responses": {
                    "200": { "description": "Pedido actualizado" }
                }
            }
        },
        "/usuario/{usuarioId}/notificaciones/leidas": {
            "get": {
                "summary": "Obtener notificaciones leídas de un usuario",
                "parameters": [
                    { "name": "usuarioId", "in": "path", "required": true, "schema": { "type": "string" } }
                ],
                "responses": {
                    "200": { "description": "Lista de notificaciones leídas" }
                }
            }
        },
        "/usuario/{usuarioId}/notificaciones/noleidas": {
            "get": {
                "summary": "Obtener notificaciones no leídas de un usuario",
                "parameters": [
                    { "name": "usuarioId", "in": "path", "required": true, "schema": { "type": "string" } }
                ],
                "responses": {
                    "200": { "description": "Lista de notificaciones no leídas" }
                }
            }
        },
        "/notificacion/{notificacionId}": {
            "patch": {
                "summary": "Marcar una notificación como leída",
                "parameters": [
                    { "name": "notificacionId", "in": "path", "required": true, "schema": { "type": "string" } }
                ],
                "responses": {
                    "200": { "description": "Notificación marcada como leída" }
                }
            }
        }
        ,
        "/usuarios/{usuarioId}/pedidos": {
            "get": {
                "summary": "Obtener pedidos de un usuario",
                "parameters": [
                    { "name": "usuarioId", "in": "path", "required": true, "schema": { "type": "string" } }
                ],
                "responses": {
                    "200": {
                        "description": "Lista de pedidos del usuario",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "array",
                                    "items": { "$ref": "#/components/schemas/Pedido" }
                                }
                            }
                        }
                    },
                    "404": { "description": "Usuario no encontrado" }
                }
            }
        },
        "/vendedores/{vendedorId}/productos": {
            "get": {
                "summary": "Obtener productos de un vendedor (con paginación y filtros)",
                "parameters": [
                    { "name": "vendedorId", "in": "path", "required": true, "schema": { "type": "string" } },
                    { "name": "page", "in": "query", "required": false, "schema": { "type": "integer", "default": 1 } },
                    { "name": "limit", "in": "query", "required": false, "schema": { "type": "integer", "default": 10 } },
                    { "name": "titulo", "in": "query", "required": false, "schema": { "type": "string" } },
                    { "name": "categoria", "in": "query", "required": false, "schema": { "type": "string" } },
                    { "name": "descripcion", "in": "query", "required": false, "schema": { "type": "string" } },
                    { "name": "precioMin", "in": "query", "required": false, "schema": { "type": "number" } },
                    { "name": "precioMax", "in": "query", "required": false, "schema": { "type": "number" } },
                    { "name": "orden", "in": "query", "required": false, "schema": { "type": "string", "enum": ["asc", "desc"] } }
                ],
                "responses": {
                    "200": {
                        "description": "Productos paginados del vendedor",
                        "content": {
                            "application/json": {
                                "schema": { "$ref": "#/components/schemas/ProductosPaginados" }
                            }
                        }
                    },
                    "404": { "description": "Vendedor no encontrado" }
                }
            }
        }
    },
    "components": {
        "schemas": {
            "Usuario": {
                "type": "object",
                "properties": {
                    "nombre": { "type": "string" },
                    "email": { "type": "string" },
                    "telefono": { "type": "string" },
                    "tipo": { "type": "string", "enum": ["Comprador", "Vendedor", "Admin"] },
                    "fechaAlta": { "type": "string", "format": "date-time" }
                },
                "required": ["nombre", "email", "telefono", "tipo", "fechaAlta"]
            },
            "Producto": {
                "type": "object",
                "properties": {
                    "nombre": { "type": "string" },
                    "descripcion": { "type": "string" },
                    "precio": { "type": "number" },
                    "stock": { "type": "integer" },
                    "categoria": { "type": "string" },
                    "vendedor": { "type": "string" }
                },
                "required": ["nombre", "precio", "stock", "categoria", "vendedor"]
            },
            "Pedido": {
                "type": "object",
                "properties": {
                    "comprador": { "type": "string" },
                    "items": { "type": "array", "items": { "type": "object" } },
                    "moneda": { "type": "string" },
                    "direccionEntrega": { "type": "object" }
                },
                "required": ["comprador", "items", "moneda", "direccionEntrega"]
            },
            "PedidoPatch": {
                "type": "object",
                "properties": {
                    "estado": { "type": "string" },
                    "usuario": { "type": "string" },
                    "motivo": { "type": "string" }
                }
            },
            "Notificacion": {
                "type": "object",
                "properties": {
                    "usuario": { "type": "string" },
                    "mensaje": { "type": "string" },
                    "leida": { "type": "boolean" },
                    "fechaLeida": { "type": "string", "format": "date-time", "nullable": true }
                }
            },
            "ProductosPaginados": {
                "type": "object",
                "properties": {
                    "pagina": { "type": "integer" },
                    "entradasPagina": { "type": "integer" },
                    "cantidadTotal": { "type": "integer" },
                    "totalPaginas": { "type": "integer" },
                    "productos": {
                        "type": "array",
                        "items": { "$ref": "#/components/schemas/Producto" }
                    }
                }
            }
        }
    }
}